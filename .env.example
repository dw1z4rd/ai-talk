GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Base URL for the remote Ollama server (used by the "-cloud" models)
# e.g. http://192.168.1.50:11434 or https://ollama.example.com
OLLAMA_CLOUD_URL=http://localhost:11434

# Optional bearer token if your Ollama server requires authentication
OLLAMA_CLOUD_API_KEY=
