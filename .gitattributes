# Normalize line endings to LF in the repository.
# On checkout, all platforms get LF in the working tree.
* text=auto eol=lf

# Explicitly force LF for all source / config / text files.
*.ts      text eol=lf
*.svelte  text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.env*    text eol=lf

# Keep binary files untouched.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
